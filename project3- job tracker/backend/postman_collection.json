    {
      "name": "Applications",
      "item": [
        {
          "name": "Create Application",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Google\",\n  \"roleTitle\": \"Frontend Intern\",\n  \"location\": \"Bangalore\",\n  \"status\": \"applied\",\n  \"jobType\": \"internship\",\n  \"applicationDate\": \"2026-07-18\",\n  \"salaryRange\": \"₹25,000/month\",\n  \"applicationLink\": \"https://careers.google.com\",\n  \"notes\": \"Applied through LinkedIn\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "applications"
              ]
            }
          }
        },
        {
          "name": "Get All Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/applications?search=google&status=applied&sortBy=applicationDate&sortOrder=desc&page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "applications"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "google"
                },
                {
                  "key": "status",
                  "value": "applied"
                },
                {
                  "key": "sortBy",
                  "value": "applicationDate"
                },
                {
                  "key": "sortOrder",
                  "value": "desc"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Application By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{applicationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "applications",
                "{{applicationId}}"
              ]
            }
          }
        },
        {
          "name": "Update Application",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"interviewing\",\n  \"notes\": \"HR scheduled a round 1 interview\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{applicationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "applications",
                "{{applicationId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Application",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/applications/{{applicationId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "applications",
                "{{applicationId}}"
              ]
            }
          }
        }
